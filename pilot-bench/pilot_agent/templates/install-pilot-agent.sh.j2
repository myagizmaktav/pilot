#!/bin/bash
set -e

echo "=== Pilot Agent: Installing Claude Code ==="

# Detect OS
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS_ID="$ID"
else
    OS_ID="unknown"
fi

echo "Detected OS: $OS_ID"

# Install Node.js + npm if not present (some images have node without npm)
if ! command -v node &> /dev/null || ! command -v npm &> /dev/null; then
    echo "Installing Node.js + npm..."
    case "$OS_ID" in
        alpine)
            apk add --no-cache nodejs npm
            ;;
        ubuntu|debian)
            apt-get update -qq && apt-get install -y -qq nodejs npm
            ;;
        fedora|rhel|centos)
            dnf install -y nodejs npm 2>/dev/null || yum install -y nodejs npm
            ;;
        *)
            # Fallback: try curl + nvm
            if command -v curl &> /dev/null; then
                curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
                apt-get install -y nodejs 2>/dev/null || apk add --no-cache nodejs npm
            else
                echo "ERROR: Cannot install Node.js — no package manager found"
                exit 1
            fi
            ;;
    esac
fi

echo "Node version: $(node --version)"
echo "npm version: $(npm --version)"

# Install Claude Code CLI globally
echo "Installing Claude Code CLI..."
npm install -g @anthropic-ai/claude-code@latest 2>&1

# Verify installation
if ! command -v claude &> /dev/null; then
    echo "ERROR: Claude Code CLI not found after installation"
    # Try common npm global paths
    export PATH="$PATH:/usr/local/bin:/usr/bin:$(npm root -g)/.bin"
    if ! command -v claude &> /dev/null; then
        echo "ERROR: Claude Code CLI still not found. Installation failed."
        exit 1
    fi
fi

echo "Claude Code version: $(claude --version 2>/dev/null || echo 'unknown')"

# Install common tools that might be missing
echo "Installing common utilities..."
case "$OS_ID" in
    alpine)
        apk add --no-cache bash curl wget git jq python3 py3-pip make gcc 2>/dev/null || true
        ;;
    ubuntu|debian)
        apt-get install -y -qq bash curl wget git jq python3 python3-pip make gcc 2>/dev/null || true
        ;;
    *)
        # Best-effort for other distros
        true
        ;;
esac

# Install Jinja2 for template-based prompt building
pip3 install --quiet jinja2 2>/dev/null || pip install --quiet jinja2 2>/dev/null || true

# Install uv/uvx — many terminal-bench verifiers depend on it
# Install early while DNS is still reliable (some sandboxes degrade over time)
echo "Installing uv (Python package manager)..."
if ! command -v uv &> /dev/null; then
    curl -LsSf https://astral.sh/uv/install.sh 2>/dev/null | sh 2>/dev/null || true
    # Add to PATH for current and future shells
    export PATH="$HOME/.local/bin:$PATH:/root/.local/bin:/root/.cargo/bin"
    # Ensure it's on PATH for verifier (runs as root)
    if [ -f /root/.local/bin/uv ]; then
        ln -sf /root/.local/bin/uv /usr/local/bin/uv 2>/dev/null || true
        ln -sf /root/.local/bin/uvx /usr/local/bin/uvx 2>/dev/null || true
    fi
    if [ -f "$HOME/.local/bin/uv" ]; then
        ln -sf "$HOME/.local/bin/uv" /usr/local/bin/uv 2>/dev/null || true
        ln -sf "$HOME/.local/bin/uvx" /usr/local/bin/uvx 2>/dev/null || true
    fi
fi
if command -v uv &> /dev/null; then
    echo "uv version: $(uv --version 2>/dev/null)"
else
    echo "WARNING: uv installation failed (verifier tests may fail)"
fi

# Create working directories
mkdir -p /installed-agent/scripts
mkdir -p /installed-agent/pilot_agent
mkdir -p /logs/agent

# Create non-root user for Claude Code
# (--dangerously-skip-permissions refuses to run as root)
if ! id pilot &>/dev/null; then
    useradd -m -s /bin/bash pilot 2>/dev/null || adduser -D -s /bin/bash pilot 2>/dev/null || true
fi
# Give pilot user ownership of workspace
chown -R pilot:pilot /app /installed-agent /logs 2>/dev/null || true

echo "=== Pilot Agent: Installation complete ==="
